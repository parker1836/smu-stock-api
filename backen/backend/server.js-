  "name": "smu-stock-api",
  "version": "1.0.0",
  "description": "Live stock prices API for SMU",
  "main": "server.js",
  "scripts": {
    "start": "node server.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "node-fetch": "^2.6.11"
  }
}
